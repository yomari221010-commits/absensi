# PostgreSQL — Railway: copy DATABASE_URL dari dashboard (JANGAN isi password asli di file ini)
DATABASE_URL=postgresql://user:password@host:port/railway

# JWT secret — generate string acak panjang (min 32 karakter)
JWT_SECRET=ubah-ini-dengan-string-rahasia-panjang-minimal-32-karakter

# Koordinat kantor Neurogs — validasi radius absensi
OFFICE_LATITUDE=-6.2906958
OFFICE_LONGITUDE=106.8095851
OFFICE_RADIUS_METERS=100
